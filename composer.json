{
    "name": "rector-ui/rector-ui",
    "description": "Browser-based upgrade workflow for Rector, served locally from a Composer-installed PHP package",
    "type": "library",
    "license": "MIT",
    "bin": [
        "bin/rector-ui"
    ],
    "autoload": {
        "psr-4": {
            "RectorUi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RectorUi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "dev": "RECTOR_UI_DEV=1 php bin/rector-ui --no-open",
        "test": "phpunit --colors=always",
        "smoke": "phpunit --colors=always tests/Integration/ServerSmokeTest.php"
    },
    "require": {
        "php": "^7.3 || ^8.0",
        "react/event-loop": "^1.5",
        "react/http": "^1.11",
        "react/socket": "^1.16",
        "ringcentral/psr7": "^1.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "config": {
        "sort-packages": true
    }
}
